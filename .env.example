# ==========================================
# AdAngle AI - Environment Configuration
# Optimized for $5M MRR Scale
# ==========================================

# ------------------------------------------
# Shopify App Credentials
# Get these from Shopify Partners Dashboard:
# https://partners.shopify.com
# ------------------------------------------
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret
SHOPIFY_SCOPES=read_products,read_content
SHOPIFY_HOST=https://your-app-domain.com

# ------------------------------------------
# OpenRouter API
# Get your API key from:
# https://openrouter.ai/keys
# ------------------------------------------
OPENROUTER_API_KEY=your_openrouter_api_key

# ------------------------------------------
# PostgreSQL Database
# Format: postgresql://user:password@host:port/database
# 
# Recommended providers for scale:
# - Supabase (free tier available)
# - Railway (easy setup)
# - Neon (serverless)
# - RDS (AWS, for serious scale)
# ------------------------------------------
DATABASE_URL=postgresql://postgres:password@localhost:5432/adangle

# Connection pool sizing
# Default 20 is good for ~10k concurrent users
# With PgBouncer, you can increase to 100+
DB_POOL_MAX=20
DB_POOL_MIN=5

# ------------------------------------------
# Redis
# Required for: sessions, job queue, caching
# 
# Recommended providers:
# - Upstash (serverless, free tier)
# - Railway (easy)
# - Redis Cloud
# - ElastiCache (AWS)
# ------------------------------------------
REDIS_URL=redis://localhost:6379

# Or use separate config:
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=your_password
# REDIS_TLS=true  # Enable for cloud providers

# ------------------------------------------
# Session Configuration
# Generate a random secret:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ------------------------------------------
SESSION_SECRET=your_random_session_secret_min_32_chars

# ------------------------------------------
# App Configuration
# ------------------------------------------
PORT=3000
NODE_ENV=development

# ------------------------------------------
# Worker Configuration
# For scale: run workers in separate process/container
# ------------------------------------------
WORKER_CONCURRENCY=5
DISABLE_WORKERS=false  # Set true if running workers separately

# ------------------------------------------
# Scaling Notes for $5M MRR
# ------------------------------------------
#
# At 50,000+ users:
# 1. Run workers in separate containers (npm run worker)
# 2. Use PgBouncer in front of PostgreSQL
# 3. Consider read replicas for products/angles
# 4. Add Redis Sentinel or Cluster for HA
# 5. Use CDN for static assets
#
# Estimated infrastructure costs at $5M MRR:
# - PostgreSQL (managed): ~$200-500/mo
# - Redis (managed): ~$50-200/mo
# - Compute (3-5 instances): ~$300-600/mo
# - OpenRouter API: ~$2,000-5,000/mo
# Total: ~$3,000-6,000/mo (~0.1% of revenue)
# ------------------------------------------
